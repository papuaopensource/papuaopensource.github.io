---
import { Image } from "astro:assets";
import HeroImage from "@/assets/images/contribution-open-source-ilustration.svg";

import Layout from "@/layouts/Layout.astro";
import Link from "@/components/Link.astro";
import TabsWrapper from "@/components/TabsWrapper";

import { Button } from "@/components/ui/button";
import { Code, RefreshCw, Share2 } from "lucide-react";
---

<Layout
  title="Cara Berkontribusi"
  description="Berkontribusi bukan hanya soal menulis kode. Ada banyak cara untuk membantu — dan semuanya berharga."
>
  <div class="min-h-screen">

    {/* Hero */}
    <section class="bg-neutral-900 py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 md:px-8">
        <div class="max-w-2xl space-y-4">
          <p class="text-xs font-semibold tracking-widest uppercase text-muted-foreground">Kontribusi</p>
          <h1 class="text-4xl font-bold sm:text-5xl">
            Semua kontribusi<br />itu berarti.
          </h1>
          <p class="text-muted-foreground text-lg leading-relaxed">
            Tidak perlu jadi developer senior untuk mulai. Kamu bisa
            berkontribusi lewat kode, desain, tulisan, atau sekadar melaporkan
            bug yang kamu temukan.
          </p>
        </div>
      </div>
    </section>

    <div class="border-t border-border"></div>

    {/* Prinsip */}
    <section class="py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 md:px-8">
        <div class="space-y-12">
          <div class="space-y-3">
            <h2 class="text-3xl font-semibold">Cara kerja kami</h2>
            <p class="text-muted-foreground text-base">
              Tiga prinsip yang menjadi fondasi komunitas Papua Open Source.
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            <div class="space-y-3">
              <div class="flex items-center justify-center w-9 h-9 rounded-md bg-secondary text-foreground">
                <Share2 className="h-4 w-4" />
              </div>
              <h3 class="font-semibold text-base">Share</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                Semua kode dibuka ke publik. Siapa pun bisa melihat, belajar,
                dan memahami cara kerja setiap proyek tanpa penghalang.
              </p>
            </div>
            <div class="space-y-3">
              <div class="flex items-center justify-center w-9 h-9 rounded-md bg-secondary text-foreground">
                <Code className="h-4 w-4" />
              </div>
              <h3 class="font-semibold text-base">Improve</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                Temukan yang kurang, perbaiki, usulkan perubahan. Tidak ada
                kode yang sempurna — selalu ada ruang untuk lebih baik.
              </p>
            </div>
            <div class="space-y-3">
              <div class="flex items-center justify-center w-9 h-9 rounded-md bg-secondary text-foreground">
                <RefreshCw className="h-4 w-4" />
              </div>
              <h3 class="font-semibold text-base">Repeat</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                Siklus ini terus berjalan. Setiap kontribusi membuka pintu bagi
                kontribusi berikutnya dari orang lain.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="border-t border-border"></div>

    {/* Cara Berkontribusi — Tabs */}
    <section class="bg-neutral-900 py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 md:px-8">
        <div class="space-y-3 mb-12">
          <h2 class="text-3xl font-semibold">Dari mana harus mulai?</h2>
          <p class="text-muted-foreground text-base">
            Pilih jalur yang paling sesuai dengan kemampuan dan minatmu.
          </p>
        </div>
        <TabsWrapper client:load />
      </div>
    </section>

    <div class="border-t border-border"></div>

    {/* Getting Started */}
    <section class="py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 md:px-8">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-20 items-start">
          <div class="space-y-6">
            <h2 class="text-3xl font-semibold">Kontribusi pertamamu</h2>
            <p class="text-muted-foreground text-base leading-relaxed">
              Kami sudah menandai beberapa issue di GitHub dengan label
              <strong class="text-foreground font-medium">"good first issue"</strong> —
              titik masuk yang ideal untuk yang baru pertama kali berkontribusi
              ke proyek open source.
            </p>
            <p class="text-muted-foreground text-base leading-relaxed">
              Kalau masih bingung, kamu juga bisa langsung tanya di Discord
              kami. Ada anggota komunitas yang siap membantu.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 pt-2">
              <Button className="font-semibold text-sm">
                <Link href="https://github.com/papuaopensource" target="_blank">
                  Lihat issue di GitHub
                </Link>
              </Button>
              <Button variant="outline" className="text-sm">
                <Link
                  href="https://discord.gg/kuW9EajFrw"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Bergabung ke Discord
                </Link>
              </Button>
            </div>
          </div>
          <div>
            <Image
              src={HeroImage}
              alt="Ilustrasi Kontribusi"
              width={600}
              height={400}
              class="rounded-xl object-cover opacity-90"
            />
          </div>
        </div>
      </div>
    </section>

  </div>
</Layout>
