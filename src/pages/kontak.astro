---
import Layout from "@/layouts/Layout.astro";
import Link from "@/components/Link.astro";

import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Github, Instagram, Mail, MapPin, Twitter } from "lucide-react";

const discordPath = "M19.27 5.33C17.94 4.71 16.5 4.26 15 4a.1.1 0 0 0-.07.03c-.18.33-.39.76-.53 1.09a16.1 16.1 0 0 0-4.8 0c-.14-.34-.35-.76-.54-1.09c-.01-.02-.04-.03-.07-.03c-1.5.26-2.93.71-4.27 1.33c-.01 0-.02.01-.03.02c-2.72 4.07-3.47 8.03-3.1 11.95c0 .02.01.04.03.05c1.8 1.32 3.53 2.12 5.24 2.65c.03.01.06 0 .07-.02c.4-.55.76-1.13 1.07-1.74c.02-.04 0-.08-.04-.09c-.57-.22-1.11-.48-1.64-.78c-.04-.02-.04-.08-.01-.11c.11-.08.22-.17.33-.25c.02-.02.05-.02.07-.01c3.44 1.57 7.15 1.57 10.55 0c.02-.01.05-.01.07.01c.11.09.22.17.33.26c.04.03.04.09-.01.11c-.52.31-1.07.56-1.64.78c-.04.01-.05.06-.04.09c.32.61.68 1.19 1.07 1.74c.03.01.06.02.09.01c1.72-.53 3.45-1.33 5.25-2.65c.02-.01.03-.03.03-.05c.44-4.53-.73-8.46-3.1-11.95c-.01-.01-.02-.02-.04-.02M8.52 14.91c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.84 2.12-1.89 2.12m6.97 0c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.83 2.12-1.89 2.12";
---

<Layout
  title="Kontak"
  description="Ada pertanyaan, ide proyek, atau sekadar ingin menyapa? Kami selalu senang mendengar dari kamu."
>
  <div class="min-h-screen">

    {/* Hero */}
    <section class="bg-neutral-900 py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 md:px-8">
        <div class="max-w-2xl space-y-4">
          <p class="text-xs font-semibold tracking-widest uppercase text-muted-foreground">Kontak</p>
          <h1 class="text-4xl font-bold sm:text-5xl">
            Ada sesuatu<br />yang ingin kamu sampaikan?
          </h1>
          <p class="text-muted-foreground text-lg leading-relaxed">
            Ide proyek baru, pertanyaan teknis, atau sekadar ingin menyapa —
            kami selalu senang mendengarnya.
          </p>
        </div>
      </div>
    </section>

    <div class="border-t border-border"></div>

    {/* Info Kontak */}
    <section class="py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 md:px-8">
        <div class="space-y-10">

          {/* Heading */}
          <div class="space-y-2">
            <h2 class="text-3xl font-semibold">Hubungi kami</h2>
            <p class="text-muted-foreground text-base max-w-lg">
              Untuk diskusi cepat, Discord adalah tempat terbaik.
              Untuk urusan lebih formal, email kami.
            </p>
          </div>

          {/* 3 contact items — horizontal grid */}
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="flex items-start gap-3 p-5 bg-card border border-border rounded-[10px]">
              <MapPin className="h-5 w-5 text-muted-foreground mt-0.5 shrink-0" />
              <div>
                <p class="text-sm font-medium mb-0.5">Lokasi</p>
                <p class="text-muted-foreground text-sm">Jayapura, Papua, Indonesia</p>
              </div>
            </div>
            <div class="flex items-start gap-3 p-5 bg-card border border-border rounded-[10px]">
              <Mail className="h-5 w-5 text-muted-foreground mt-0.5 shrink-0" />
              <div>
                <p class="text-sm font-medium mb-0.5">Email</p>
                <p class="text-muted-foreground text-sm">contact@papuaopensource.org</p>
              </div>
            </div>
            <div class="flex items-start gap-3 p-5 bg-card border border-border rounded-[10px]">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 text-muted-foreground mt-0.5 shrink-0 fill-current">
                <path d={discordPath} />
              </svg>
              <div>
                <p class="text-sm font-medium mb-0.5">Discord</p>
                <Link
                  href="https://discord.gg/kuW9EajFrw"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-muted-foreground text-sm hover:text-foreground transition-colors"
                >
                  discord.gg/kuW9EajFrw
                </Link>
              </div>
            </div>
          </div>

          {/* Bottom row: social */}
          <div class="flex items-center gap-3 pt-2 border-t border-border">
            <span class="text-sm text-muted-foreground">Ikuti kami</span>
            <div class="flex gap-2">
              <Button variant="outline" size="icon" className="h-9 w-9" asChild>
                <Link href="https://github.com/papuaopensource" target="_blank" rel="noopener noreferrer">
                  <Github className="h-4 w-4" />
                  <span class="sr-only">GitHub</span>
                </Link>
              </Button>
              <Button variant="outline" size="icon" className="h-9 w-9" asChild>
                <Link href="https://instagram.com/papuaopensource" target="_blank" rel="noopener noreferrer">
                  <Instagram className="h-4 w-4" />
                  <span class="sr-only">Instagram</span>
                </Link>
              </Button>
              <Button variant="outline" size="icon" className="h-9 w-9" asChild>
                <Link href="https://x.com/papuaopensource" target="_blank" rel="noopener noreferrer">
                  <Twitter className="h-4 w-4" />
                  <span class="sr-only">Twitter/X</span>
                </Link>
              </Button>
            </div>
          </div>

        </div>
      </div>
    </section>

    <div class="border-t border-border"></div>

    {/* FAQ */}
    <section class="bg-neutral-900 py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 md:px-8">
        <div class="space-y-10">
          <h2 class="text-3xl font-semibold">Pertanyaan yang sering muncul</h2>
          <div class="space-y-2 w-full">
            <Card className="w-full bg-card border border-border shadow-none rounded-[10px]">
              <CardHeader className="pb-2">
                <CardTitle className="text-base font-semibold">Apa itu Papua Open Source?</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  Komunitas pengembang dan pecinta teknologi yang membangun perangkat
                  lunak terbuka untuk Papua. Semua proyek kami gratis, bisa
                  dipelajari, dan bisa dikembangkan oleh siapa saja.
                </p>
              </CardContent>
            </Card>
            <Card className="w-full bg-card border border-border shadow-none rounded-[10px]">
              <CardHeader className="pb-2">
                <CardTitle className="text-base font-semibold">Bagaimana cara bergabung?</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  Langsung bergabung ke Discord kami atau follow repositori GitHub
                  kami. Tidak ada formulir pendaftaran, tidak ada syarat khusus —
                  cukup datang dan mulai berkontribusi.
                </p>
              </CardContent>
            </Card>
            <Card className="w-full bg-card border border-border shadow-none rounded-[10px]">
              <CardHeader className="pb-2">
                <CardTitle className="text-base font-semibold">Apakah harus bisa coding untuk berkontribusi?</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  Tidak. Kamu bisa berkontribusi lewat dokumentasi, desain,
                  terjemahan, pelaporan bug, atau memberikan ide dan masukan.
                  Semua bentuk kontribusi kami hargai.
                </p>
              </CardContent>
            </Card>
            <Card className="w-full bg-card border border-border shadow-none rounded-[10px]">
              <CardHeader className="pb-2">
                <CardTitle className="text-base font-semibold">Apakah proyek-proyek ini gratis?</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  Ya. Semua proyek kami bersifat open source dan gratis — untuk
                  digunakan, dimodifikasi, dan disebarkan sesuai lisensi
                  masing-masing proyek.
                </p>
              </CardContent>
            </Card>
            <Card className="w-full bg-card border border-border shadow-none rounded-[10px]">
              <CardHeader className="pb-2">
                <CardTitle className="text-base font-semibold">Bagaimana cara melaporkan bug?</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  Buat "issue" di repositori GitHub proyek yang bersangkutan.
                  Sertakan deskripsi yang jelas dan langkah-langkah untuk
                  mereproduksi bug, beserta tangkapan layar jika bisa.
                </p>
              </CardContent>
            </Card>
            <Card className="w-full bg-card border border-border shadow-none rounded-[10px]">
              <CardHeader className="pb-2">
                <CardTitle className="text-base font-semibold">Apakah ada event atau meetup?</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  Ya, kami sesekali mengadakan meetup, workshop, dan hackathon.
                  Informasinya diumumkan lewat media sosial dan Discord kami.
                  Pantau terus agar tidak ketinggalan.
                </p>
              </CardContent>
            </Card>
          </div>
        </div>
      </div>
    </section>

  </div>
</Layout>
